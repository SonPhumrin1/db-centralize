# Coolify deployment environment for DataPlatform.
# Copy this to .env inside docker/coolify and replace example values.

# Public domains
APP_PUBLIC_URL=https://app.example.com
API_PUBLIC_URL=https://api.example.com

# Container ports
API_PORT=8080
FRONTEND_PORT=3000

# Internal service URLs
DATABASE_URL=postgres://dp:replace-postgres-password@postgres:5432/dataplatform
REDIS_URL=redis://redis:6379
INTERNAL_API_URL=http://backend:8080

# Secrets
ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
BETTER_AUTH_SECRET=replace-with-long-random-secret
POSTGRES_PASSWORD=replace-postgres-password

# Bootstrap admin
BOOTSTRAP_ROOT_USERNAME=root
BOOTSTRAP_ROOT_PASSWORD=replace-initial-root-password
